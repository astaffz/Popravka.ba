@{
    Layout = "_Layout";
    ViewData["Title"] = "500 Not Found - Popravka.ba";
}

<section class="error-page">
    <div class="error-page-inner">
        <img src="~/images/bugojno.webp" alt="Aleksandar Vučić u frižideru" class="error-page-image" />
        <h1 class="error-page-code">404</h1>
        <h2 class="error-page-title">Stranica nije pronađena</h2>
        <p class="error-page-text">
            Dobrodošli u Bugojno.
        </p>
        <a asp-controller="Home" asp-action="Index" class="error-page-btn">
            Nazad na početnu
        </a>
    </div>
</section>