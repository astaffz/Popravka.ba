@model ErrorViewModel?
@{
    ViewData["Title"] = "500 Internal Server Error - Popravka.ba";
    Layout = null;
}

<!DOCTYPE html>
<html lang="bs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Noto+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
            :root {
                --blue: #1a6fd4;
                --blue-dark: #1558aa;
                --blue-darker: #1e3a8a;
                --text: #1a1a2e;
                --text-muted: #6b7280;
                --text-soft: #9ca3af;
                --border: #e5e7eb;
                --bg: #f3f4f6;
                --white: #ffffff;
                --red: #ef4444;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Noto Sans', system-ui, sans-serif;
            }

            html, body {
                height: 100%;
            }

            body {
                background: var(--bg);
                color: var(--text);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 2rem;
            }

            .error-page-inner {
                background: var(--white);
                max-width: 520px;
                width: 100%;
                padding: 3rem 2.5rem;
                border-radius: 14px;
                box-shadow: 0 12px 30px rgba(16,24,40,0.08);
                border: 1px solid rgba(16,24,40,0.03);
                text-align: center;
            }

            .error-page-img {
                max-width: 320px;
                width: 100%;
                height: auto;
                margin: 0 auto 1.75rem;
                display: block;
            }

            .error-page-code {
                font-family: 'Plus Jakarta Sans', sans-serif;
                font-size: 4rem;
                font-weight: 800;
                color: var(--blue-darker);
                line-height: 1;
                margin-bottom: 0.5rem;
            }

            .error-page-title {
                font-family: 'Plus Jakarta Sans', sans-serif;
                font-size: 1.4rem;
                font-weight: 700;
                color: var(--text);
                margin-bottom: 0.6rem;
            }

            .error-page-text {
                color: var(--text-muted);
                font-size: 0.95rem;
                margin-bottom: 2rem;
                line-height: 1.5;
            }

            .error-page-btn {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                padding: 0.85rem 2rem;
                background: var(--blue);
                color: var(--white);
                border-radius: 8px;
                font-weight: 700;
                font-size: 1rem;
                text-decoration: none;
                transition: background 0.15s ease;
            }

                .error-page-btn:hover {
                    background: var(--blue-dark);
                }

            .error-details {
                margin: 1.5rem 0;
                padding: 1rem;
                background: #fef2f2;
                border: 1px solid #fecaca;
                border-radius: 8px;
                text-align: left;
            }

                .error-details p {
                    font-size: 0.875rem;
                    color: var(--red);
                    margin-bottom: 0.5rem;
                }

                .error-details pre {
                    font-size: 0.75rem;
                    color: #7f1d1d;
                    white-space: pre-wrap;
                    word-break: break-word;
                    max-height: 240px;
                    overflow: auto;
                    background: rgba(0,0,0,0.03);
                    padding: 0.6rem;
                    border-radius: 6px;
                }

            .error-meta {
                font-size: 0.8rem;
                color: var(--text-soft);
                margin-bottom: 1.5rem;
            }

                .error-meta code {
                    background: var(--bg);
                    padding: 0.1rem 0.4rem;
                    border-radius: 4px;
                }
    </style>
</head>
<body>
    <div class="error-page-inner">

        <img src="~/images/vucic-tuche-parizer.jpg" alt="Aleksandar Vučić tuče parizer" class="error-page-img" />

        <h1 class="error-page-code">500</h1>
        <h2 class="error-page-title">Interna greška servera</h2>
        <p class="error-page-text">
            Nešto je interno pošlo po zlu na našoj strani. Molimo pokušajte ponovo za nekoliko trenutaka.
        </p>

        @if (Model?.ShowRequestId == true)
        {
            <p class="error-meta"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
        }

        @if (!string.IsNullOrEmpty(Model?.ExceptionMessage))
        {
            <div class="error-details">
                <p><strong>Greška:</strong> @Model.ExceptionMessage</p>
                @if (!string.IsNullOrEmpty(Model.StackTrace))
                {
                    <pre>@Model.StackTrace</pre>
                }
            </div>
        }

        <a asp-controller="Home" asp-action="Index" class="error-page-btn">
            Nazad na početnu
        </a>
    </div>
</body>
</html>