@model HomeViewModel
@using System.Reflection
@{
    ViewData["Title"] = "Popravka.ba - Vaš online prostor za provjerene usluge";
}

<section class="hero">
    <div class="hero-inner">
        <h1 class="hero-title">
            Vaš online prostor<br>
            <span class="hero-title-accent">za provjerene usluge.</span>
        </h1>

        <div class="hero-actions">
            <a class="hero-btn" asp-controller="Oglas" asp-action="Pretraga">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="7"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                Pretraži majstore
            </a>
            <a class="hero-btn hero-btn--primary" asp-controller="Oglas" asp-action="ObjaviOglas">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                Postavi oglas
            </a>
        </div>

        <p class="hero-stat">@Model.BrojRealiziranihUsluga+ uspješno realiziranih usluga.</p>

        <form class="hero-search" asp-controller="Oglas" asp-action="Index" method="get">
            <div class="hero-search-input">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="7"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" name="pretragaTekst" placeholder="Treba mi... (Vodoinstalater, Naziv majstora/firme, ...)" 
                oninput="this.value = this.value.trimStart()" onchange="this.value = this.value.trim()"
                />
            </div>

            <div class="hero-search-select-wrapper">
                <div class="hero-search-select-display" id="lokacijaDisplay">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" />
                        <circle cx="12" cy="9" r="2.5" />
                    </svg>
                    <span id="lokacijaLabel">Lokacija</span>
                </div>
                <input type="hidden" name="lokacija" id="lokacijaValue" value="" />

                <div class="lokacija-dropdown" id="lokacijaDropdown">
                    <div class="lokacija-search-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="7"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <input type="text" id="lokacijaSearch" placeholder="Pretraži mjesto..." autocomplete="off"
                        oninput="this.value = this.value.trimStart()" onchange="this.value = this.value.trim()"
                        />
                    </div>
                    <div class="lokacija-options" id="lokacijaOptions">
                        @{
                            var byKantonGroups = Model.Mjesta.GroupBy(m => m.Kanton).OrderBy(g => (int)g.Key);
                        }
                        @foreach (var group in byKantonGroups)
                        {
                            var kantonName = group.Key.GetType()
                                .GetMember(group.Key.ToString())
                                .First()
                                .GetCustomAttributes(typeof(System.ComponentModel.DataAnnotations.DisplayAttribute), false)
                                .Cast<System.ComponentModel.DataAnnotations.DisplayAttribute>()
                                .FirstOrDefault()?.Name ?? group.Key.ToString();

                            <div class="lokacija-group-label" data-group="@kantonName">@kantonName</div>
                            @foreach (var m in group.OrderBy(m => m.Naziv))
                            {
                                <div class="lokacija-option" data-value="@m.MjestoID" data-label="@m.Naziv" data-group="@kantonName">
                                    @m.Naziv
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <button type="submit" class="hero-search-submit">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="7"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                Pretraži
            </button>
        </form>
    </div>
   
</section>
<section class="kategorije-section">
    <div class="kategorije-inner">
        <div class="kategorije-header">
            <h2 style="display:block;text-align:center;margin:0;">Usluge na raspolaganju</h2>

            <a asp-controller="Oglas" asp-action="Pretraga">Pogledaj sve →</a>
        </div>
        <div class="kategorije-grid">
        @foreach (var kategorijaTuple in Model.TopKategorije)
         {
            // TODO: Usaglasit sa Tarikovim argumentima kada završi pretragu
            <a asp-controller = "Oglas" asp-action = "Pretraga" asp-route-kategorijaID="@kategorijaTuple.ID" class="kategorija-card">
                <strong>@kategorijaTuple.Naziv</strong>
                <span>@kategorijaTuple.AktivniIzvrsilacCount majstora</span>
            </a>
           
          }
        </div>
    </div>
</section>
<section class="oglasi-section">
    <div class="oglasi-inner">
        <div class="oglasi-header">
            <h2>Nedavno objavljeni oglasi</h2>
            <a asp-controller="Oglas" asp-action="Index">Pogledaj još →</a>
        </div>
        <div class="oglasi-grid">
            @foreach (var oglas in new[] {
                new { Naziv = "Montaža novog bojlera", Opis = "Potrebna montaža novog bojlera od 100L. Postoji priprema. Hitno za sutra.", Autor = "Esmir B.", BrojPonuda = 5 },
                new { Naziv = "Renoviranje kuhinje - stolarski radovi", Opis = "Potrebna je izrada kuhinjskih elemenata po mjeri. Dimenzije prostorije su 3x4m.", Autor = "Kerim A.", BrojPonuda = 3 },
                new { Naziv = "Popravka curenja vode u kupatilu", Opis = "Potrebno je zamijeniti spojni ventil i provjeriti cijelu instalaciju ispod sudopere. Preferiram majstora koji može izaći u roku od 24 sata.", Autor = "Edin Dž.", BrojPonuda = 1 },
            })
            {
                <a class="oglas-card" href="#">
                    <div class="oglas-body">
                        <strong>@oglas.Naziv</strong>
                        <p>@oglas.Opis</p>
                    </div>
                    <div class="oglas-footer">
                        <span class="oglas-autor"><i class="fa-solid fa-circle-user"></i> @oglas.Autor</span>
                        <span>Ponuda primljeno: @oglas.BrojPonuda</span>
                    </div>
                </a>
            }
        </div>
    </div>
</section>
@if (!User.Identity.IsAuthenticated)
{
    <section class="cta-section">
        <div class="cta-inner">
            <div class="cta-content">
                <h2 class="cta-title">Majstor ste ili imate firmu?</h2>
                <p class="cta-text">Pridružite se Popravka.ba platformi i plasirajte vaše usluge potencijalnim klijentima još danas!</p>
                <a class="hero-btn" asp-controller="Account" asp-action="Registracija">Registriraj nalog</a>
            </div>
            <div class="cta-image">
                <i class="fa-solid fa-helmet-safety"></i>
            </div>
        </div>
    </section>
}

@section Scripts {
    <script>
        (function () {
            const display  = document.getElementById('lokacijaDisplay');
            const label    = document.getElementById('lokacijaLabel');
            const input    = document.getElementById('lokacijaValue');
            const dropdown = document.getElementById('lokacijaDropdown');
            const search   = document.getElementById('lokacijaSearch');
            const options  = document.querySelectorAll('.lokacija-option');
            const groups   = document.querySelectorAll('.lokacija-group-label');

            function closeDropdown() {
                dropdown.classList.remove('open');
                search.value = '';
                options.forEach(o => o.style.display = '');
                groups.forEach(g => g.style.display = '');
            }

            display.addEventListener('click', (e) => {
                e.stopPropagation();
                dropdown.classList.toggle('open');
                if (dropdown.classList.contains('open')) search.focus();
                else closeDropdown();
            });

            document.addEventListener('click', closeDropdown);
            dropdown.addEventListener('click', e => e.stopPropagation());

            search.addEventListener('input', () => {
                const q = search.value.toLowerCase();
                const visibleGroups = new Set();

                options.forEach(opt => {
                    const match = opt.dataset.label.toLowerCase().includes(q);
                    opt.style.display = match ? '' : 'none';
                    if (match) visibleGroups.add(opt.dataset.group);
                });

                groups.forEach(g => {
                    g.style.display = visibleGroups.has(g.dataset.group) ? '' : 'none';
                });
            });

            options.forEach(opt => {
                opt.addEventListener('click', () => {
                    input.value = opt.dataset.value;
                    label.textContent = opt.dataset.label;
                    options.forEach(o => o.classList.remove('selected'));
                    opt.classList.add('selected');
                    closeDropdown();
                });
            });
        })();
    </script>
}