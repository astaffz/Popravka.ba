@model IEnumerable<PopravkaBa.Domain.Models.Recenzija>
@{
    ViewData["Title"] = "Recenzije - " + (ViewBag.IzvrsilacIme ?? "Popravka.ba");
    var recenzije = Model.ToList();
}

<div class="container mt-4 mb-5" style="max-width:760px;">
    <a href="/Profil/@ViewBag.IzvrsilacUsername" class="text-muted text-decoration-none small d-block mb-3">
        <i class="fa-solid fa-arrow-left me-1"></i>Nazad na profil
    </a>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <h3 class="fw-bold mb-1">Recenzije</h3>
    <p class="text-muted mb-4">
        @ViewBag.IzvrsilacIme — @recenzije.Count @(recenzije.Count == 1 ? "recenzija" : "recenzije")
    </p>

    @if (!recenzije.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 text-center text-muted">Još nema recenzija.</div>
        </div>
    }
    else
    {
        @foreach (var r in recenzije)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center gap-2">
                        <span class="rec-avatar">
                            @if (!string.IsNullOrEmpty(r.Klijent?.Slika))
                            {
                                <img src="@r.Klijent.Slika" alt="@r.Klijent.DisplayName" />
                            }
                            else
                            {
                                <i class="bi bi-person-fill"></i>
                            }
                        </span>
                        <div>
                            <strong class="d-block">@(r.Klijent?.DisplayName ?? "Klijent")</strong>
                            <small class="text-muted">@r.DatumRecenzije.ToString("dd.MM.yyyy.")</small>
                        </div>
                        <div class="ms-auto" style="color:#1e6fe0;">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi @(i <= r.Ocjena ? "bi-star-fill" : "bi-star")"></i>
                            }
                        </div>
                    </div>
                    <p class="mb-1 mt-2" style="color:#4b5563;">@r.Komentar</p>
                    <div style="display: flex; gap: 1rem; margin-top: .75rem; flex-wrap: wrap;">
                        @if (ViewBag.JeVlasnik == true)
                        {
                            @if (r.Prijavljena)
                            {
                                <small style="color:#d97706;"><i class="bi bi-flag-fill"></i> Prijavljena — čeka pregled</small>
                            }
                            else
                            {
                                <a asp-action="Prijavi" asp-route-recenzijaId="@r.RecenzijaID"
                                   class="small text-muted text-decoration-none rec-prijavi">
                                    <i class="bi bi-flag"></i> Prijavi
                                </a>
                            }
                        }
                        @if (User.IsInRole("Administrator"))
                        {
                            <form asp-controller="Admin" asp-action="UkloniRecenziju" method="post" style="display: inline; margin: 0;"
                                  onsubmit="return confirm('Obrisati ovu recenziju? Ova akcija je trajna.');" novalidate>
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="recenzijaId" value="@r.RecenzijaID" />
                                <button type="submit" style="background: none; border: none; color: #dc2626; text-decoration: none; padding: 0; cursor: pointer; font-size: .875rem; font-weight: 500;">
                                    <i class="bi bi-trash-fill"></i> Obriši
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

<style>
    .rec-avatar {
        width: 42px; height: 42px;
        border-radius: 50%;
        background: #e5e7eb;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
        overflow: hidden;
        flex-shrink: 0;
    }
    .rec-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .rec-prijavi:hover { color: #dc2626 !important; }
</style>
