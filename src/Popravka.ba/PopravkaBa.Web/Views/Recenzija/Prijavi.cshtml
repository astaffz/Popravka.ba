@model PopravkaBa.Domain.Models.Recenzija
@{
    ViewData["Title"] = "Prijavi recenziju - Popravka.ba";
}

<div class="container mt-4 mb-5" style="max-width:640px;">
    <a href="/Profil/@Model.Izvrsilac?.UserName" class="text-muted text-decoration-none small d-block mb-3">
        <i class="fa-solid fa-arrow-left me-1"></i>Nazad na profil
    </a>

    <h3 class="fw-bold mb-4">Prijavi recenziju</h3>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Recenzija koja se prijavljuje -->
    <div class="card border-0 shadow-sm mb-3" style="background:#f9fafb;">
        <div class="card-body p-3">
            <div class="d-flex align-items-center gap-2 mb-1">
                <strong>@(Model.Klijent?.DisplayName ?? "Klijent")</strong>
                <small class="text-muted">@Model.DatumRecenzije.ToString("dd.MM.yyyy.")</small>
                <div class="ms-auto" style="color:#1e6fe0;">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi @(i <= Model.Ocjena ? "bi-star-fill" : "bi-star")"></i>
                    }
                </div>
            </div>
            <p class="mb-0 fst-italic" style="color:#4b5563;">"@Model.Komentar"</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form asp-action="Prijavi" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="RecenzijaID" value="@Model.RecenzijaID" />

                <div class="mb-3">
                    <label class="form-label fw-medium">Razlog prijave <span class="text-danger">*</span></label>
                    <textarea name="RazlogPrijave" class="form-control" rows="4" minlength="10" maxlength="500" required
                              placeholder="Objasnite zašto smatrate da je ova recenzija neprikladna (uvredljiv sadržaj, lažne tvrdnje, spam...)">@(ViewBag.RazlogPrijave as string)</textarea>
                    <div class="form-text">Najmanje 10 karaktera. Prijavu će pregledati administrator i odlučiti hoće li recenzija biti uklonjena.</div>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a href="/Profil/@Model.Izvrsilac?.UserName" class="btn btn-outline-secondary">Odustani</a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-flag me-1"></i>Prijavi recenziju
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
