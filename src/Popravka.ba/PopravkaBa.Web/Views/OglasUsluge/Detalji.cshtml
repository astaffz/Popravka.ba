@model PopravkaBa.Web.Models.ViewModels.OglasUslugeDetaljiViewModel
@using PopravkaBa.Domain.Enums
@{
    ViewData["Title"] = Model.Naslov + " – Popravka.ba";
    bool jeAktivan = Model.StatusOglasa == Status.Aktivan;

    string statusLabel(Status s) => s switch
    {
        Status.Aktivan    => "Aktivan",
        Status.Neaktivan  => "Neaktivan",
        Status.Isporuceno => "Završen",
        Status.Prihvaceno => "Prihvaćen",
        _                 => s.ToString()
    };
    string statusBadgeClass(Status s) => s switch
    {
        Status.Aktivan    => "bg-success",
        Status.Isporuceno => "bg-info",
        _                 => "bg-secondary"
    };

    Func<DateTime, string> relativnoVrijeme = (DateTime d) =>
    {
        var diff = DateTime.UtcNow - d.ToUniversalTime();
        if (diff.TotalMinutes < 60) return $"Prije {(int)diff.TotalMinutes} min.";
        if (diff.TotalHours < 24) return $"Prije {(int)diff.TotalHours}h.";
        return $"Prije {(int)diff.TotalDays} dana";
    };

    Func<decimal, string> ocjenaStars = (decimal ocjena) =>
    {
        int pune = (int)Math.Round(ocjena);
        var sb = new System.Text.StringBuilder();
        for (int i = 1; i <= 5; i++) sb.Append(i <= pune ? "★" : "☆");
        return sb.ToString();
    };

    string tipIsplateLabel(TipIsplate t) => t switch
    {
        TipIsplate.PoSatu     => "/h",
        TipIsplate.Jednokratno => " fiksno",
        TipIsplate.Sedmicno   => "/sedm.",
        TipIsplate.Mjesecno   => "/mj.",
        _ => ""
    };
}

<!-- Confirmation modal -->
<div id="confirmModal" class="confirm-modal-overlay" style="display:none;" aria-modal="true" role="dialog">
    <div class="confirm-modal-box">
        <p id="confirmModalText" class="confirm-modal-text"></p>
        <div class="confirm-modal-actions">
            <button type="button" class="btn btn-secondary btn-sm" id="confirmModalCancel">Odustani</button>
            <button type="button" class="btn btn-danger btn-sm"    id="confirmModalOk">Potvrdi</button>
        </div>
    </div>
</div>

<div class="container mt-4 mb-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!jeAktivan)
    {
        <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span><strong>Oglas je neaktivan.</strong> Ponuda je već prihvaćena ili je oglas zatvoren. Prijave više nisu moguće.</span>
        </div>
    }

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Početna</a></li>
            <li class="breadcrumb-item"><a asp-controller="Pretraga" asp-action="Index" asp-route-AktivniTab="Oglasi za popravke">Oglasi za popravke</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Naslov</li>
        </ol>
    </nav>

    <div class="row g-4">

        <!-- Lijeva kolona -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h1 class="h3 fw-bold mb-0">@Model.Naslov</h1>
                        <span class="badge @statusBadgeClass(Model.StatusOglasa) ms-3 flex-shrink-0">
                            @statusLabel(Model.StatusOglasa)
                        </span>
                    </div>

                    <div class="d-flex flex-wrap gap-3 text-muted small mb-3">
                        <span><i class="fa-solid fa-location-dot me-1"></i>@(Model.Lokacija ?? "—")</span>
                        <span><i class="fa-regular fa-clock me-1"></i>@relativnoVrijeme(Model.DatumObjave)</span>
                        <span><i class="fa-solid fa-list-check me-1"></i>@Model.Ponude.Count @(Model.Ponude.Count == 1 ? "ponuda" : "ponude")</span>
                    </div>

                    @if (Model.Kategorije.Any())
                    {
                        <div class="mb-3">
                            @foreach (var kat in Model.Kategorije)
                            {
                                <span class="badge bg-primary-subtle text-primary me-1">@kat</span>
                            }
                        </div>
                    }

                    <div class="alert alert-info py-2 mb-3">
                        <i class="fa-solid fa-coins me-2"></i>
                        <strong>Budžet:</strong> @Model.MinBudzet – @Model.MaxBudzet KM
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Slika))
                    {
                        <img src="@Model.Slika" alt="@Model.Naslov"
                             class="img-fluid rounded mb-3 w-100" style="max-height:360px;object-fit:cover;" />
                    }

                    @if (!string.IsNullOrEmpty(Model.Opis))
                    {
                        <hr />
                        <h5 class="fw-semibold">Opis</h5>
                        <p class="mb-0" style="white-space: pre-line;">@Model.Opis</p>
                    }
                </div>
            </div>

            <!-- Ponude -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-semibold">
                        <i class="fa-solid fa-handshake me-2 text-primary"></i>
                        Ponude (@Model.Ponude.Count)
                    </h5>
                </div>
                <div class="card-body p-0">
                    @if (!Model.Ponude.Any())
                    {
                        <div class="p-4 text-center text-muted">
                            <i class="fa-solid fa-inbox fa-2x mb-2 d-block"></i>
                            Još nema ponuda za ovaj oglas.
                        </div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var ponuda in Model.Ponude)
                            {
                                <li class="list-group-item p-3 @(ponuda.StatusPonude == Status.Prihvaceno ? "list-group-item-success" : ponuda.StatusPonude == Status.Odbijeno ? "list-group-item-light" : "")">
                                    <div class="d-flex align-items-start gap-3">
                                        <a href="/Profil/@ponuda.IzvrsilacUsername" class="flex-shrink-0">
                                            @if (!string.IsNullOrEmpty(ponuda.IzvrsilacSlika))
                                            {
                                                <img src="@ponuda.IzvrsilacSlika" alt="@ponuda.IzvrsilacIme"
                                                     class="rounded-circle" style="width:52px;height:52px;object-fit:cover;" />
                                            }
                                            else
                                            {
                                                <span class="rounded-circle bg-secondary-subtle d-flex align-items-center justify-content-center"
                                                      style="width:52px;height:52px;font-size:1.6rem;color:#6c757d;">
                                                    <i class="fa-solid fa-circle-user"></i>
                                                </span>
                                            }
                                        </a>

                                        <div class="flex-grow-1">
                                            <div class="d-flex flex-wrap justify-content-between align-items-center">
                                                <div>
                                                    <a href="/Profil/@ponuda.IzvrsilacUsername" class="fw-semibold text-decoration-none text-body">
                                                        @ponuda.IzvrsilacIme
                                                    </a>
                                                    @if (!string.IsNullOrEmpty(ponuda.IzvrsilacKategorija))
                                                    {
                                                        <span class="badge bg-primary-subtle text-primary ms-2 small">@ponuda.IzvrsilacKategorija</span>
                                                    }
                                                </div>

                                                @if (ponuda.Cijena.HasValue)
                                                {
                                                    <div class="text-end">
                                                        <span class="fw-bold fs-5">@ponuda.Cijena KM@(tipIsplateLabel(ponuda.TipIsplate))</span>
                                                        @if (ponuda.RazlikaOdProsjeka.HasValue && ponuda.RazlikaOdProsjeka.Value != 0)
                                                        {
                                                            var razlika = ponuda.RazlikaOdProsjeka.Value;
                                                            <br />
                                                            <small class="@(razlika < 0 ? "text-success" : "text-danger")">
                                                                @(razlika < 0 ? $"{Math.Abs(razlika):F0} KM ispod prosjeka" : $"{razlika:F0} KM iznad prosjeka")
                                                            </small>
                                                        }
                                                    </div>
                                                }
                                            </div>

                                            <div class="d-flex align-items-center gap-2 my-1 small text-muted">
                                                <span class="izv-stars text-warning">@ocjenaStars(ponuda.ProsjecnaOcjena)</span>
                                                <span>@ponuda.ProsjecnaOcjena.ToString("F1") (@ponuda.BrojRecenzija recenzija)</span>
                                            </div>

                                            <div class="small text-muted">
                                                <i class="fa-regular fa-calendar-check me-1"></i>
                                                Početak: @ponuda.DatumPocetka.ToString("dd.MM.yyyy")
                                                @if (ponuda.DatumKraja.HasValue)
                                                {
                                                    <span class="ms-2">
                                                        <i class="fa-regular fa-calendar-xmark me-1"></i>
                                                        Kraj: @ponuda.DatumKraja.Value.ToString("dd.MM.yyyy")
                                                    </span>
                                                }
                                            </div>

                                            @if (!string.IsNullOrEmpty(ponuda.Poruka))
                                            {
                                                <p class="small text-muted mt-1 mb-0 fst-italic">"@ponuda.Poruka"</p>
                                            }

                                            @if (ponuda.StatusPonude != Status.NaCekanju)
                                            {
                                                <span class="badge @(ponuda.StatusPonude == Status.Prihvaceno ? "bg-success" : "bg-secondary") mt-1">
                                                    @(ponuda.StatusPonude == Status.Prihvaceno ? "✓ Prihvaćena" : "Odbijena")
                                                </span>
                                            }
                                            else if (Model.JeVlasnik)
                                            {
                                                <!-- Akcije vlasnika — koristimo modal za potvrdu -->
                                                <div class="mt-2 d-flex gap-2">
                                                    <form asp-controller="PonudaUsluge" asp-action="Prihvati" method="post" class="confirm-form">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="ponudaId" value="@ponuda.PonudaId" />
                                                        <input type="hidden" name="oglasId" value="@Model.OglasId" />
                                                        <button type="button" class="btn btn-success btn-sm confirm-btn"
                                                                data-msg="Prihvatiti ponudu od @ponuda.IzvrsilacIme? Sve ostale ponude bit će automatski odbijene.">
                                                            <i class="fa-solid fa-check me-1"></i>Prihvati
                                                        </button>
                                                    </form>
                                                    <form asp-controller="PonudaUsluge" asp-action="Odbij" method="post" class="confirm-form">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="ponudaId" value="@ponuda.PonudaId" />
                                                        <input type="hidden" name="oglasId" value="@Model.OglasId" />
                                                        <button type="button" class="btn btn-outline-danger btn-sm confirm-btn"
                                                                data-msg="Odbiti ponudu od @ponuda.IzvrsilacIme?">
                                                            <i class="fa-solid fa-xmark me-1"></i>Odbij
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <!-- Desna kolona -->
        <div class="col-lg-4">

            <!-- Vlasnik oglasa -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-3">
                    <h6 class="fw-semibold text-muted mb-3 text-uppercase" style="font-size:0.75rem;letter-spacing:.05em;">Naručilac</h6>
                    <a href="/Profil/@Model.VlasnikUsername" class="d-flex align-items-center gap-3 text-decoration-none text-body">
                        @if (!string.IsNullOrEmpty(Model.VlasnikSlika))
                        {
                            <img src="@Model.VlasnikSlika" alt="@Model.VlasnikDisplayName"
                                 class="rounded-circle" style="width:48px;height:48px;object-fit:cover;" />
                        }
                        else
                        {
                            <span class="rounded-circle bg-secondary-subtle d-flex align-items-center justify-content-center flex-shrink-0"
                                  style="width:48px;height:48px;font-size:1.5rem;color:#6c757d;">
                                <i class="fa-solid fa-circle-user"></i>
                            </span>
                        }
                        <span class="fw-semibold">@Model.VlasnikDisplayName</span>
                    </a>
                </div>
            </div>

            <!-- Neprijavljen korisnik -->
            @if (!User.Identity!.IsAuthenticated && jeAktivan)
            {
                <div class="card shadow-sm border-0 mb-4" style="background:linear-gradient(135deg,#1a73e8,#0d47a1);color:#fff;">
                    <div class="card-body p-3 text-center">
                        <i class="fa-solid fa-hard-hat fa-2x mb-2 d-block"></i>
                        <h6 class="fw-semibold mb-1">Želite ponuditi svoje usluge?</h6>
                        <p class="small mb-3" style="opacity:.85;">Samo verificirani radnici mogu slati ponude za oglase na platformi.</p>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-light btn-sm w-100 fw-semibold">
                            Pristupite nalogu
                        </a>
                        <a asp-controller="Account" asp-action="Registracija" class="btn btn-outline-light btn-sm w-100 mt-1">
                            Registrujte se
                        </a>
                    </div>
                </div>
            }

            <!-- Pošalji ponudu -->
            @if (Model.MozeApplicirati && jeAktivan)
            {
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-3">
                        @if (Model.VecApplicirao)
                        {
                            <div class="alert alert-secondary mb-0 py-2 text-center">
                                <i class="fa-solid fa-circle-check me-1"></i>Već ste poslali ponudu za ovaj oglas.
                            </div>
                        }
                        else
                        {
                            <h6 class="fw-semibold mb-3">Pošalji ponudu</h6>
                            <form asp-controller="PonudaUsluge" asp-action="PosaljiPonudu" method="post" novalidate class="confirm-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="OglasUslugeID" value="@Model.OglasId" />
                                <div class="mb-2">
                                    <label class="form-label small fw-medium">Datum početka</label>
                                    <input type="text" name="DatumPocetkaUsluge" autocomplete="off" placeholder="dd/mm/yyyy"
                                           class="form-control form-control-sm js-datepicker" required />
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small fw-medium">Očekivani završetak <span class="text-muted">(opcionalno)</span></label>
                                    <input type="text" name="DatumOcekivanogZavrsetka" autocomplete="off" placeholder="dd/mm/yyyy"
                                           class="form-control form-control-sm js-datepicker" />
                                </div>
                                <div class="row g-2 mb-2">
                                    <div class="col-6">
                                        <label class="form-label small fw-medium">Cijena (KM)</label>
                                        <input type="number" name="Cijena" class="form-control form-control-sm" min="0" placeholder="npr. 50" required />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label small fw-medium">Tip isplate</label>
                                        <select name="TipIsplate" class="form-select form-select-sm">
                                            <option value="1">Po satu</option>
                                            <option value="0">Jednokratno</option>
                                            <option value="2">Sedmično</option>
                                            <option value="3">Mjesečno</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small fw-medium">Poruka <span class="text-muted">(opcionalno)</span></label>
                                    <textarea name="Poruka" class="form-control form-control-sm" rows="3" maxlength="500"
                                              placeholder="Kratko se predstavite..."></textarea>
                                </div>
                                <p class="text-muted mb-2" style="font-size:.75rem;">
                                    Napomena: ponuda se ne može povući, a po oglasu možete poslati samo jednu ponudu.
                                </p>
                                <button type="button" class="btn btn-primary w-100 confirm-btn"
                                        data-msg="Ponuda se ne može povući, a po oglasu možete poslati samo jednu ponudu. Želite li poslati ponudu?">
                                    <i class="fa-solid fa-paper-plane me-2"></i>Pošalji ponudu
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }

            <!-- Vlasnik/Admin: uredi/obriši (samo za aktivne oglase) -->
            @if (Model.JeVlasnik && jeAktivan)
            {
                <div class="card shadow-sm border-0">
                    <div class="card-body p-3 d-flex flex-column gap-2">
                        <a asp-controller="OglasUsluge" asp-action="UrediOglas" asp-route-id="@Model.OglasId"
                           class="btn btn-outline-primary btn-sm">
                            <i class="fa-solid fa-pen-to-square me-1"></i>Uredi oglas
                        </a>
                        <form asp-controller="OglasUsluge" asp-action="ObrisiOglas" method="post" class="confirm-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.OglasId" />
                            <button type="button" class="btn btn-outline-danger btn-sm w-100 confirm-btn"
                                    data-msg="Jeste li sigurni da želite obrisati ovaj oglas? Oglas će biti deaktiviran i više neće biti vidljiv.">
                                <i class="fa-solid fa-trash me-1"></i>Obriši oglas
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>

    </div>
</div>

<style>
.confirm-modal-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.45);
    backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
}
.confirm-modal-box {
    background: #fff;
    border-radius: .75rem;
    padding: 1.75rem 2rem;
    max-width: 380px; width: 90%;
    box-shadow: 0 8px 32px rgba(0,0,0,.18);
    text-align: center;
}
.confirm-modal-text { font-size: 1rem; margin-bottom: 1.25rem; line-height: 1.5; }
.confirm-modal-actions { display: flex; gap: .75rem; justify-content: center; }
</style>

@section Scripts {
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
(function () {
    // ---- Datum picker (prikaz dd/mm/yyyy, server prima ISO yyyy-MM-dd) ----
    if (window.flatpickr) {
        flatpickr('.js-datepicker', {
            dateFormat: 'Y-m-d',   // vrijednost koja se šalje serveru
            altInput: true,
            altFormat: 'd/m/Y',    // ono što korisnik vidi i unosi
            minDate: 'today',
            allowInput: true
        });
    }
})();

(function () {
    // ---- Confirm modal (Prihvati/Odbij/Obriši) ----
    var overlay = document.getElementById('confirmModal');
    if (!overlay) return;
    var modalText = document.getElementById('confirmModalText');
    var btnOk = document.getElementById('confirmModalOk');
    var btnCancel = document.getElementById('confirmModalCancel');
    var pendingForm = null;

    document.querySelectorAll('.confirm-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            pendingForm = btn.closest('.confirm-form');
            modalText.textContent = btn.dataset.msg;
            overlay.style.display = 'flex';
        });
    });

    btnOk.addEventListener('click', function () {
        overlay.style.display = 'none';
        if (pendingForm) pendingForm.submit();
    });
    btnCancel.addEventListener('click', function () {
        overlay.style.display = 'none';
        pendingForm = null;
    });
    overlay.addEventListener('click', function (e) {
        if (e.target === overlay) { overlay.style.display = 'none'; pendingForm = null; }
    });
})();
</script>
}
