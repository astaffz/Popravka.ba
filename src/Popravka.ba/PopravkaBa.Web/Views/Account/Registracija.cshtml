@using PopravkaBa.Web.Models.ViewModels
@model RegistracijaViewModel
@{
    Layout = null;
    ViewData["Title"] = Model.ActiveTab == PopravkaBa.Web.Models.Enums.AuthTab.Registracija ? "Registracija - Popravka.ba" : "Prijava - Popravka.ba";
}
@functions {
    static string KantonNaziv(PopravkaBa.Domain.Enums.Kanton k)
        => k.GetType().GetMember(k.ToString()).First()
            .GetCustomAttributes(typeof(System.ComponentModel.DataAnnotations.DisplayAttribute), false)
            .Cast<System.ComponentModel.DataAnnotations.DisplayAttribute>()
            .FirstOrDefault()?.Name ?? k.ToString();
}
<!DOCTYPE html>
<html lang="bs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Noto+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --blue: #1a6fd4;
            --blue-dark: #1558aa;
            --blue-darker: #1e3a8a;
            --blue-light: #e8f0fb;
            --text: #1a1a2e;
            --text-muted: #6b7280;
            --text-soft: #9ca3af;
            --border: #e5e7eb;
            --bg: #f3f4f6;
            --white: #ffffff;
            --red: #ef4444;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Noto Sans', system-ui, sans-serif; }
        html, body { height: 100%; }
        body { background: var(--bg); color: var(--text); height: 100vh; display: flex; overflow: hidden; }

        .split { display: flex; height: 100vh; width: 100%; }

        /* Left panel - fixed in place */
        .panel-blue {
    flex: 0 0 55%;
    background: var(--blue-darker);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 3rem;
    position: relative;
    overflow: hidden;
    height: 100vh;
}
.panel-blue::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, transparent 60%);
    pointer-events: none;
}

.panel-link {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-decoration: none;
    transition: transform 0.2s ease;
}
.panel-link:hover {
    transform: scale(1.03);
}

.panel-logo {

    max-width: 60%;
    display: block;
}

.panel-logo-text {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: 0.02em;
}
        /* Right panel - scrollable */
        .panel-form { flex: 0 0 45%; display: flex; align-items: center; justify-content: flex-start; padding: 4rem 3rem; flex-direction:column; height: 100vh; overflow-y: auto; }
        .form-container { width: 100%; max-width: 520px; }

        .card { background: var(--white); padding: 2rem 2.5rem; border-radius: 12px; box-shadow: 0 10px 25px rgba(16,24,40,0.06); border:1px solid rgba(16,24,40,0.03); }
            .back-link {
                display: flex;
                width: 100%;
                max-width: 520px;
                text-align:left;
                color: var(--blue-darker);
                font-weight: 600;
                text-decoration: none;
                margin-bottom: 0.75rem;
				padding: 0.25rem 0.5rem 0.5rem;
            }
        .card-header { display:flex; justify-content:space-between; align-items:flex-start; gap:1rem; margin-bottom:0.5rem; }
        .card-title { font-family:'Plus Jakarta Sans', sans-serif; font-size:1.25rem; font-weight:800; }
        .card-sub { color:var(--text-muted); font-size:0.9rem; }

        /* top tabs */
        .auth-tabs { display:inline-flex; background: #f3f4f6; border-radius:8px; padding:4px; gap:6px; }
        .auth-tab { padding:6px 12px; border-radius:6px; font-weight:700; color:var(--text-muted); cursor:pointer; }
        .auth-tab.active { background:#fff; color:var(--blue-darker); box-shadow:0 1px 0 rgba(16,24,40,0.04) inset; }

        /* type selector cards */
        .type-grid { display:flex; gap:0.6rem; margin:0.6rem 0 1rem 0; }
        .type-card { flex:1 1 0; height:72px; border-radius:8px; border:1px solid var(--border); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px; background:#fff; cursor:pointer; }
        .type-card .icon { width:28px; height:28px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:#f3f4f6; color:var(--text-soft); }
        .type-card.active { border-color: var(--blue); box-shadow: 0 4px 10px rgba(11,95,214,0.06); }

        .two-col { display:grid; grid-template-columns: 1fr 1fr; gap:0.75rem; }

        .form-title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1.75rem;
            font-weight: 800;
            margin-bottom: 0.4rem;
        }
        .form-subtitle {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 1rem;
        }

        .register-type-group { display:flex; gap:0.5rem; margin:1rem 0 1.25rem 0; }
        .register-type-btn {
            flex:1; padding:0.6rem 0.75rem; border-radius:999px; border:1px solid var(--border); background:var(--white); color:var(--text); font-weight:700; cursor:pointer;
        }
        .register-type-btn.active { background: var(--blue); color: #fff; border-color: var(--blue); }

        /* Form fields */
        .field { margin-bottom: 0.75rem; }
        .field-label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 0.3rem;
        }

        .input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }
        .input-icon {
            position: absolute;
            left: 0.9rem;
            width: 18px;
            height: 18px;
            color: var(--text-soft);
            pointer-events: none;
        }
        .input-toggle {
            position: absolute;
            right: 0.75rem;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: transparent;
            border: none;
            color: var(--text-soft);
            cursor: pointer;
            border-radius: 4px;
            transition: color 0.15s ease, background 0.15s ease;
        }
        .input-toggle:hover { color: var(--text-muted); background: var(--bg); }
        .input-toggle svg { width: 18px; height: 18px; }

        .field-input {
            width: 100%;
            padding: 0.5rem 0.75rem 0.5rem 2.6rem;
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 0.9rem;
            color: var(--text);
            font-family: inherit;
            outline: none;
            transition: border-color 0.15s ease, box-shadow 0.15s ease;
        }
        .field-input::placeholder { color: var(--text-soft); }
        .field-input:focus {
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(26, 111, 212, 0.12);
        }
        .field-input--password { padding-right: 3rem; }

        .field-error {
            display: block;
            font-size: 0.8rem;
            color: var(--red);
            margin-top: 0.35rem;
        }

        /* Submit button */
        .btn-submit {
            width: 100%;
            padding: 0.85rem;
            background: var(--blue);
            color: var(--white);
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.15s ease;
            font-family: inherit;
            margin-top: 0.5rem;
        }
        .btn-submit:hover { background: var(--blue-dark); }

        .panel-logo { max-width: 260px; }
        .panel-logo-text { font-size: 2.25rem; margin-top:0.5rem }
        .panel-center { display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; }

        
        /* multi-select chips */
        .multi-select { border: 1px solid var(--border); padding:0.5rem; border-radius:8px; background:#fff; }
        .ms-chips { display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:0.5rem; }
        .ms-chip { background:#eef6ff; color:var(--blue-darker); padding:0.25rem 0.5rem; border-radius:999px; font-size:0.85rem; display:inline-flex; gap:0.4rem; align-items:center; }
        .ms-chip button { border:0;background:transparent; cursor:pointer;color:var(--blue-darker); font-weight:700; }
        .ms-input { width:100%; border:0; outline:none; padding:0.4rem 0.25rem; }
        .ms-dropdown { border:1px solid var(--border); max-height:200px; overflow:auto; margin-top:0.35rem; border-radius:6px; display:none; background:#fff; }
        .ms-item { padding:0.5rem; cursor:pointer; }
        .ms-item:hover { background:#f3f4f6; }

        
        .validation-summary {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            margin-bottom: 1rem;
        }
        .validation-summary ul { list-style: none; padding: 0; margin: 0; }
        .validation-summary li { color: var(--red); font-size: 0.875rem; }

        .form-meta {
            display: flex;
            justify-content: flex-end;
            margin-top: 0.75rem;
        }
        .form-link {
            color: var(--blue);
            font-size: 0.875rem;
            font-weight: 600;
            text-decoration: none;
        }
        .form-link:hover { text-decoration: underline; }

        .form-footer {
            text-align: center;
            margin-top: 2rem;
            font-size: 0.9rem;
            color: var(--text-muted);
        }
        .form-footer a {
            color: var(--blue);
            font-weight: 600;
            text-decoration: none;
        }
        .form-footer a:hover { text-decoration: underline; }

      .error-page-btn {
          width:60%;
    display: inline-flex relative;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 2rem;
    background: #1e6fe0;
    margin-bottom:auto;
    color: #ffffff;
    border-radius: 4px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s ease;
}

        /* plain text inputs (no leading icon) */
        .field-input--plain { padding-left: 0.9rem; }

        /* ===== Combobox (searchable dropdown, like homepage lokacija) ===== */
        .combo { position: relative; }
        .combo + .combo { margin-top: 0.6rem; }

        .combo-control {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.35rem;
            min-height: 42px;
            padding: 0.35rem 2.2rem 0.35rem 0.6rem;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: var(--white);
            cursor: pointer;
            outline: none;
            transition: border-color 0.15s ease, box-shadow 0.15s ease;
        }
        .combo-control:focus,
        .combo.open .combo-control {
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(26,111,212,0.12);
        }
        .combo.disabled .combo-control {
            background: #f9fafb;
            cursor: not-allowed;
            opacity: 0.7;
        }

        .combo-placeholder { color: var(--text-soft); font-size: 0.9rem; }
        .combo-placeholder.chosen { color: var(--text); font-weight: 600; }
        .combo-control.has-value .combo-placeholder { display: none; }

        .combo-caret {
            position: absolute;
            right: 0.75rem;
            width: 16px; height: 16px;
            color: var(--text-soft);
            pointer-events: none;
            transition: transform 0.15s ease;
        }
        .combo.open .combo-caret { transform: rotate(180deg); }

        .combo-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            background: var(--blue-light);
            color: var(--blue-darker);
            padding: 0.15rem 0.45rem;
            border-radius: 999px;
            font-size: 0.8rem;
            font-weight: 600;
        }
        .combo-chip button {
            border: 0; background: transparent; cursor: pointer;
            color: var(--blue-darker); font-weight: 700; line-height: 1;
            padding: 0; font-size: 0.95rem;
        }

        .combo-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 4px);
            left: 0; right: 0;
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 8px;
            overflow: hidden;
            z-index: 50;
            box-shadow: 0 8px 24px rgba(16,24,40,0.12);
        }
        .combo.open .combo-dropdown { display: block; }

        .combo-search-wrap {
            display: flex; align-items: center; gap: 0.5rem;
            padding: 0.45rem 0.7rem;
            border-bottom: 1px solid var(--border);
        }
        .combo-search-wrap svg { width: 15px; height: 15px; flex-shrink: 0; color: var(--text-soft); }
        .combo-search { width: 100%; border: 0; outline: none; font-size: 0.875rem; font-family: inherit; color: var(--text); }

        .combo-options { max-height: 220px; overflow-y: auto; }
        .combo-group {
            padding: 0.45rem 0.85rem 0.2rem;
            font-size: 0.68rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.06em;
            color: var(--blue-dark);
            border-top: 1px solid var(--border);
            margin-top: 0.2rem;
        }
        .combo-group:first-child { border-top: 0; margin-top: 0; }
        .combo-option {
            padding: 0.5rem 0.85rem;
            font-size: 0.875rem; font-weight: 500;
            cursor: pointer; color: var(--text);
            transition: background 0.12s ease, color 0.12s ease;
        }
        .combo-option:hover { background: #f3f4f6; }
        .combo-option.selected { background: var(--blue); color: #fff; }
        .combo-option.hidden, .combo-group.hidden { display: none; }
        .combo-empty { padding: 0.6rem 0.85rem; font-size: 0.85rem; color: var(--text-soft); }

        /* ===== Logo upload ===== */
        .logo-drop {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.25rem;
            padding: 1rem;
            border: 1px dashed var(--border);
            border-radius: 8px;
            text-align: center;
            color: var(--text-soft);
            cursor: pointer;
            transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
        }
        .logo-drop:hover { border-color: var(--blue); background: #f8fbff; }
        .logo-drop svg { width: 22px; height: 22px; }
        .logo-drop small { font-size: 0.75rem; }
        .logo-drop.has-file { border-style: solid; border-color: var(--blue); color: var(--text); background: #f8fbff; }
        .logo-drop-text { font-size: 0.875rem; font-weight: 600; }


			.form-check {
				display: flex;
				gap: 0.4rem;
				align-content: center;
				margin-top: 0.5rem;
			}

			
    </style>
</head>
<body>
    <div class="split">
        <div class="panel-blue">
            <a asp-controller="Home" asp-action="Index" class="panel-link" aria-label="Popravka.ba početna">
                <img src="~/images/logo512.png" alt="Popravka.ba" class="panel-logo" />
                <span class="panel-logo-text">Popravka.ba</span>
             </a>
        </div>

        <div class="panel-form">
            <a asp-controller="Home" asp-action="Index" class="back-link">Nazad</a>
            <div class="form-container card">
                <div class="card-header">
                   
                </div>
                <div style="display:flex;gap:1rem;align-items:center;margin-bottom:1rem;">
                    <div class="auth-tabs">
                        <div id="tab-login" class="auth-tab @(Model.ActiveTab==PopravkaBa.Web.Models.Enums.AuthTab.Prijava?"active":"")" onclick="showTab('login')">Prijava</div>
                        <div id="tab-register" class="auth-tab @(Model.ActiveTab==PopravkaBa.Web.Models.Enums.AuthTab.Registracija?"active":"")" onclick="showTab('register')">Registracija</div>
                    </div>
                </div>

                <div id="login-panel" style="display:@(Model.ActiveTab==PopravkaBa.Web.Models.Enums.AuthTab.Prijava?"block":"none");">
                    <h1 class="form-title">Dobrodošli nazad</h1>
                    <p class="form-subtitle">Unesite vaše podatke za pristup nalogu.</p>

                    <form asp-action="Login" asp-controller="Account" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                        <div class="field">
                            <label asp-for="Login.EmailUsername" class="field-label">E-mail adresa ili korisničko ime</label>
                            <div class="input-wrap">
                                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                                    <polyline points="22,6 12,13 2,6"></polyline>
                                </svg>
                                <input asp-for="Login.EmailUsername" class="field-input" placeholder="vas@email.com" autocomplete="username" />
                            </div>
                            <span asp-validation-for="Login.EmailUsername" class="field-error"></span>
                        </div>

                        <div class="field">
                            <label asp-for="Login.Lozinka" class="field-label">Lozinka</label>
                            <div class="input-wrap">
                                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                </svg>
                                <input asp-for="Login.Lozinka" id="lozinkaInput" type="password" class="field-input field-input--password" placeholder="••••••••" autocomplete="current-password" />
                                <button type="button" class="input-toggle" onclick="togglePassword()" aria-label="Prikaži lozinku">
                                    <svg id="eyeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                        <circle cx="12" cy="12" r="3"></circle>
                                    </svg>
                                </button>
                            </div>
                            <span asp-validation-for="Login.Lozinka" class="field-error"></span>
                            <div class="form-check">
                                <input asp-for="Login.ZapamtiMe" class="form-check-input" />
                                <label asp-for="Login.ZapamtiMe" class="field-label">Zapamti me</label>
                            </div>
                            <div class="form-meta">
                                <a asp-controller="Account" asp-action="ZaboravljenaLozinka" class="form-link">Zaboravili ste lozinku?</a>
                            </div>
                        </div>

                        <button type="submit" class="btn-submit">Prijavi se</button>
                    </form>

                    <p class="form-footer">Nemate račun? <a asp-controller="Account" asp-action="Registracija">Registrujte se</a></p>
                </div>

                @{
                    // Koji je tip registracije aktivan (npr. nakon neuspjelog POST-a vrati se na isti tab).
                    var aktivniRegTip = Model.FirmaDTO != null ? "firma"
                        : Model.MajstorDTO != null ? "majstor"
                        : "klijent";
                }
                <div id="register-panel" data-aktivni-tip="@aktivniRegTip" style="display:@(Model.ActiveTab==PopravkaBa.Web.Models.Enums.AuthTab.Registracija?"block":"none");">
                    <h1 class="form-title">Kreirajte nalog</h1>
                    <p class="form-subtitle">Popunite podatke i počnite koristiti platformu.</p>

                    <label style="font-weight:700;margin-bottom:6px;display:block;color:var(--text);">Prijavljujem se kao...</label>
                    <div class="type-grid">
                        <div id="card-klijent" class="type-card @(aktivniRegTip == "klijent" ? "active" : "")" onclick="showRegisterType('klijent')"><div class="icon">👤</div><div style="font-size:0.85rem;color:var(--text-soft);">Klijent</div></div>
                        <div id="card-majstor" class="type-card @(aktivniRegTip == "majstor" ? "active" : "")" onclick="showRegisterType('majstor')"><div class="icon">🔧</div><div style="font-size:0.85rem;color:var(--text-soft);">Majstor</div></div>
                        <div id="card-firma" class="type-card @(aktivniRegTip == "firma" ? "active" : "")" onclick="showRegisterType('firma')"><div class="icon">🏢</div><div style="font-size:0.85rem;color:var(--text-soft);">Firma</div></div>
                    </div>

                    @{
                        var nadkategorije = Model.Kategorije.Where(k => k.NadkategorijaID == null).OrderBy(k => k.Naziv).ToList();
                        var potkategorije = Model.Kategorije.Where(k => k.NadkategorijaID != null).OrderBy(k => k.Naziv).ToList();
                        var mjestaPoKantonu = Model.Mjesta.GroupBy(m => m.Kanton).OrderBy(g => (int)g.Key).ToList();
                    }

                    <!-- Klijent form -->
                    <div id="reg-klijent" style="display:@(aktivniRegTip == "klijent" ? "block" : "none");">
                        <form asp-controller="Account" asp-action="RegistracijaKlijenta" method="post" novalidate>
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                            <div class="field">
                                <label asp-for="KlijentDTO.KorisnickoIme" class="field-label">Korisničko ime</label>
                                <input asp-for="KlijentDTO.KorisnickoIme" class="field-input field-input--plain" autocomplete="username" />
                                <span asp-validation-for="KlijentDTO.KorisnickoIme" class="field-error"></span>
                            </div>
                            <div class="two-col">
                                <div class="field"><label asp-for="KlijentDTO.Ime" class="field-label">Ime</label><input asp-for="KlijentDTO.Ime" class="field-input field-input--plain" /><span asp-validation-for="KlijentDTO.Ime" class="field-error"></span></div>
                                <div class="field"><label asp-for="KlijentDTO.Prezime" class="field-label">Prezime</label><input asp-for="KlijentDTO.Prezime" class="field-input field-input--plain" /><span asp-validation-for="KlijentDTO.Prezime" class="field-error"></span></div>
                            </div>
                            <div class="field"><label asp-for="KlijentDTO.Email" class="field-label">E-mail adresa</label><input asp-for="KlijentDTO.Email" class="field-input field-input--plain" /><span asp-validation-for="KlijentDTO.Email" class="field-error"></span></div>
                            <div class="two-col">
