    <script>
        function togglePassword() {
            const input = document.getElementById('lozinkaInput');
            const icon = document.getElementById('eyeIcon');
            const isHidden = input.type === 'password';

            input.type = isHidden ? 'text' : 'password';

            // swap icon between "eye" and "eye-off"
            if (isHidden) {
                icon.innerHTML = `
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
                    <line x1="1" y1="1" x2="23" y2="23"></line>
                `;
            } else {
                icon.innerHTML = `
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                `;
            }
        }
    </script>
    <script>
        // ===== Searchable comboboxes (lokacija + kaskadno zanimanje) =====
        (function () {
            function closeAll(except) {
                document.querySelectorAll('.combo.open').forEach(c => { if (c !== except) c.classList.remove('open'); });
            }
            document.addEventListener('click', (e) => { if (!e.target.closest('.combo')) closeAll(); });

            // Show/hide options based on search text, parent filter and already-selected values.
            function filterOptions(combo, { query = '', parent = null, selected = null } = {}) {
                const q = query.toLowerCase();
                const groups = combo.querySelectorAll('.combo-group');
                const options = combo.querySelectorAll('.combo-option');
                const visibleGroups = new Set();
                let anyVisible = false;

                options.forEach(opt => {
                    let vis = opt.dataset.label.toLowerCase().includes(q);
                    if (parent != null && opt.dataset.parent !== String(parent)) vis = false;
                    if (selected && selected.has(opt.dataset.value)) vis = false;
                    opt.classList.toggle('hidden', !vis);
                    if (vis) { anyVisible = true; if (opt.dataset.group) visibleGroups.add(opt.dataset.group); }
                });
                groups.forEach(g => g.classList.toggle('hidden', !visibleGroups.has(g.dataset.group)));

                let empty = combo.querySelector('.combo-empty');
                if (!anyVisible) {
                    if (!empty) {
                        empty = document.createElement('div');
                        empty.className = 'combo-empty';
                        empty.textContent = 'Nema rezultata.';
                        combo.querySelector('.combo-options').appendChild(empty);
                    }
                    empty.style.display = '';
                } else if (empty) {
                    empty.style.display = 'none';
                }
            }

            function wireToggle(combo, onOpen) {
                const control = combo.querySelector('.combo-control');
                const search = combo.querySelector('.combo-search');
                control.addEventListener('click', (e) => {
                    if (e.target.closest('.combo-chip')) return;
                    if (combo.classList.contains('disabled')) return;
                    const willOpen = !combo.classList.contains('open');
                    closeAll(combo);
                    combo.classList.toggle('open', willOpen);
                    if (willOpen) { if (onOpen) onOpen(); if (search) search.focus(); }
                });
            }

            // Multi-select combo with chips + one hidden <input> per selected value.
            function createMultiCombo(combo, { name, hiddenContainer, max, getParent }) {
                const control = combo.querySelector('.combo-control');
                const chipsWrap = combo.querySelector('.combo-chips');
                const search = combo.querySelector('.combo-search');
                const selected = new Map(); // value -> label

                function refilter() {
                    filterOptions(combo, { query: search ? search.value : '', parent: getParent ? getParent() : null, selected });
                }

                function sync() {
                    chipsWrap.innerHTML = '';
                    hiddenContainer.innerHTML = '';
                    selected.forEach((label, value) => {
                        const chip = document.createElement('span');
                        chip.className = 'combo-chip';
                        const text = document.createElement('span');
                        text.textContent = label;
                        const btn = document.createElement('button');
                        btn.type = 'button';
                        btn.setAttribute('aria-label', 'Ukloni');
                        btn.textContent = '×';
                        btn.addEventListener('click', (e) => { e.stopPropagation(); selected.delete(value); sync(); });
                        chip.appendChild(text);
                        chip.appendChild(btn);
                        chipsWrap.appendChild(chip);

                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = name;
                        input.value = value;
                        hiddenContainer.appendChild(input);
                    });
                    control.classList.toggle('has-value', selected.size > 0);
                    refilter();
                }

                combo.querySelectorAll('.combo-option').forEach(opt => {
                    opt.addEventListener('click', () => {
                        const value = opt.dataset.value;
                        if (selected.has(value)) return;
                        if (max && selected.size >= max) return;
                        selected.set(value, opt.dataset.label);
                        if (search) search.value = '';
                        sync();
                    });
                });

                if (search) search.addEventListener('input', refilter);
                wireToggle(combo, refilter);
                return { refilter };
            }

            // Single-select combo; shows chosen label in place of the placeholder.
            function createSingleCombo(combo, { onSelect }) {
                const placeholder = combo.querySelector('.combo-placeholder');
                const search = combo.querySelector('.combo-search');

                function refilter() { filterOptions(combo, { query: search ? search.value : '' }); }

                combo.querySelectorAll('.combo-option').forEach(opt => {
                    opt.addEventListener('click', () => {
                        combo.querySelectorAll('.combo-option').forEach(o => o.classList.remove('selected'));
                        opt.classList.add('selected');
                        placeholder.textContent = opt.dataset.label;
                        placeholder.classList.add('chosen');
                        combo.classList.remove('open');
                        if (onSelect) onSelect(opt.dataset.value, opt.dataset.label);
                    });
                });

                if (search) search.addEventListener('input', refilter);
                wireToggle(combo, refilter);
            }

            // Cascading "zanimanje": pick Nadkategorija, then its specific Kategorije.
            function setupCascade(cascade) {
                const nadCombo = cascade.querySelector('.combo[data-role="nad"]');
                const potCombo = cascade.querySelector('.combo[data-role="pot"]');
                const potPlaceholder = potCombo.querySelector('.combo-placeholder');
                const hidden = cascade.querySelector('.combo-hidden');
                let currentParent = null;

                const multi = createMultiCombo(potCombo, {
                    name: cascade.dataset.name,
                    hiddenContainer: hidden,
                    max: parseInt(cascade.dataset.max, 10) || Infinity,
                    getParent: () => currentParent
                });

                createSingleCombo(nadCombo, {
                    onSelect: (value) => {
                        currentParent = value;
                        potCombo.classList.remove('disabled');
                        potPlaceholder.textContent = 'Odaberite kategoriju...';
                        multi.refilter();
                    }
                });
            }

            document.addEventListener('DOMContentLoaded', function () {
                document.querySelectorAll('.cascade').forEach(setupCascade);

                // Standalone multi combos (lokacija); skip the ones owned by a cascade.
                document.querySelectorAll('.combo[data-combo="multi"]').forEach(combo => {
                    if (combo.dataset.role) return;
                    createMultiCombo(combo, {
                        name: combo.dataset.name,
                        hiddenContainer: combo.querySelector('.combo-hidden'),
                        max: parseInt(combo.dataset.max, 10) || Infinity
                    });
                });

                // Logo upload: prikaži ime odabranog fajla.
                const logoInput = document.getElementById('logoInput');
                if (logoInput) {
                    const drop = document.getElementById('logoDrop');
                    const text = document.getElementById('logoDropText');
                    logoInput.addEventListener('change', () => {
                        if (logoInput.files && logoInput.files.length) {
                            text.textContent = logoInput.files[0].name;
                            drop.classList.add('has-file');
                        } else {
                            text.textContent = 'Kliknite za upload';
                            drop.classList.remove('has-file');
                        }
                    });
                }
            });
        })();
    </script>
    <script>
        function showTab(tab) {
            document.getElementById('login-panel').style.display = tab === 'login' ? 'block' : 'none';
            document.getElementById('register-panel').style.display = tab === 'register' ? 'block' : 'none';
            document.getElementById('tab-login').classList.toggle('active', tab === 'login');
            document.getElementById('tab-register').classList.toggle('active', tab === 'register');
        }

        function showRegisterType(type) {
            document.getElementById('reg-klijent').style.display = type === 'klijent' ? 'block' : 'none';
            document.getElementById('reg-majstor').style.display = type === 'majstor' ? 'block' : 'none';
            document.getElementById('reg-firma').style.display = type === 'firma' ? 'block' : 'none';

            // toggle active state on type cards
            document.getElementById('card-klijent').classList.toggle('active', type === 'klijent');
            document.getElementById('card-majstor').classList.toggle('active', type === 'majstor');
            document.getElementById('card-firma').classList.toggle('active', type === 'firma');
        }
    </script>

    @* Ova stranica koristi Layout = null pa _Layout ne ubacuje site.js — uključujemo ga ručno
       radi zaštite od dvostrukog slanja forme (double POST). *@
    <script src="~/js/site.js" asp-append-version="true"></script>

    @section Scripts {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.4/jquery.min.js" integrity="" crossorigin="anonymous"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js" integrity="" crossorigin="anonymous"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js" integrity="" crossorigin="anonymous"></script>
            <script>
                // ===== Global trimming for all text inputs =====
                (function () {
                // Trim leading whitespace live as the user types (no trailing — they may be mid-word).
                document.addEventListener('input', function (e) {
                const el = e.target;
                if (!el.matches('input[type="text"], input[type="email"], input:not([type])')) return;
                if (el.classList.contains('combo-search')) return;  // search boxes handle their own
                const start = el.selectionStart;
                const trimmed = el.value.replace(/^\s+/, '');
                if (trimmed !== el.value) {
                const diff = el.value.length - trimmed.length;
                el.value = trimmed;
                el.setSelectionRange(Math.max(0, start - diff), Math.max(0, start - diff));
                }
                });

                // Full trim (both ends) on blur and right before submit.
                function fullTrim(el) { el.value = el.value.trim(); }

                document.addEventListener('blur', function (e) {
                const el = e.target;
                if (el.matches('input[type="text"], input[type="email"], input:not([type])')
                && !el.classList.contains('combo-search')) {
                fullTrim(el);
                }
                }, true);  // capture phase — blur doesn't bubble

                document.querySelectorAll('form').forEach(form => {
                form.addEventListener('submit', function () {
                form.querySelectorAll('input[type="text"], input[type="email"], input:not([type])')
                .forEach(el => { if (!el.classList.contains('combo-search')) fullTrim(el); });
                });
                });
                })();
            </script>
    }
</body>
