@using PopravkaBa.Web.Models.ViewModels
@model RegistracijaViewModel
@{
    Layout=null;

}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Noto+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --blue: #1a6fd4;
            --blue-dark: #1558aa;
            --blue-light: #e8f0fb;
            --text: #1a1a2e;
            --text-muted: #6b7280;
            --border: #e5e7eb;
            --bg: #f3f4f6;
            --white: #ffffff;
            --red: #ef4444;
            --red-light: #fee2e2;
            --green: #27ae60;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Noto Sans', system-ui, sans-serif;
        }

        body {
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
        }

        .split {
            display: flex;
            min-height: 100vh;
            width: 100%;
        }
        .panel-blue { flex: 1; background: var(--blue); display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 3rem; position: relative; overflow: hidden;   gap: 0.5rem; }
        .panel-blue::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,0.07) 0%, transparent 60%); pointer-events: none; }
        .panel-logo-icon { width: 38px; height: 38px; background: white; border-radius: 10px; display: flex; align-items: center; justify-content: center; }
        .panel-logo-icon svg { width: 22px; height: 22px; color: var(--blue); }
        .panel-logo-text { font-weight: 800; font-size: 1.4rem; color: white; }
  
    </style>
</head>
<body>
    <div class="split">
        <div class="panel-blue">
            <svg class="panel-logo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
            </svg>
            <span class="panel-logo-text">Popravka.ba</span>
        </div>
    </div>
</body>
</html>
