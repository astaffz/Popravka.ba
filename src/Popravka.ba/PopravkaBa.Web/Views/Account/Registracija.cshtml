@using PopravkaBa.Web.Models.ViewModels
@model RegistracijaViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="bs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Noto+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --blue: #1a6fd4;
            --blue-dark: #1558aa;
            --blue-darker: #1e3a8a;
            --blue-light: #e8f0fb;
            --text: #1a1a2e;
            --text-muted: #6b7280;
            --text-soft: #9ca3af;
            --border: #e5e7eb;
            --bg: #f3f4f6;
            --white: #ffffff;
            --red: #ef4444;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Noto Sans', system-ui, sans-serif; }
        body { background: var(--bg); color: var(--text); min-height: 100vh; display: flex; }

        .split { display: flex; min-height: 100vh; width: 100%; }

        /* Left panel */
        .panel-blue {
    flex: 1;
    background: var(--blue-darker);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    position: relative;
    overflow: hidden;
}
.panel-blue::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, transparent 60%);
    pointer-events: none;
}

.panel-link {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-decoration: none;
    transition: transform 0.2s ease;
}
.panel-link:hover {
    transform: scale(1.03);
}

.panel-logo {

    max-width: 60%;
    display: block;
}

.panel-logo-text {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: 0.02em;
}
        /* Right panel */
        .panel-form { flex: 1; display: flex; align-items: center; justify-content: center; padding: 2rem; flex-direction:column;}
        .form-container { width: 100%; max-width: 420px; }

        .form-title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1.75rem;
            font-weight: 800;
            margin-bottom: 0.4rem;
        }
        .form-subtitle {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 2rem;
        }

        /* Form fields */
        .field { margin-bottom: 1.25rem; }
        .field-label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 0.5rem;
        }

        .input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }
        .input-icon {
            position: absolute;
            left: 0.9rem;
            width: 18px;
            height: 18px;
            color: var(--text-soft);
            pointer-events: none;
        }
        .input-toggle {
            position: absolute;
            right: 0.75rem;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: transparent;
            border: none;
            color: var(--text-soft);
            cursor: pointer;
            border-radius: 4px;
            transition: color 0.15s ease, background 0.15s ease;
        }
        .input-toggle:hover { color: var(--text-muted); background: var(--bg); }
        .input-toggle svg { width: 18px; height: 18px; }

        .field-input {
            width: 100%;
            padding: 0.75rem 0.9rem 0.75rem 2.6rem;
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 0.95rem;
            color: var(--text);
            font-family: inherit;
            outline: none;
            transition: border-color 0.15s ease, box-shadow 0.15s ease;
        }
        .field-input::placeholder { color: var(--text-soft); }
        .field-input:focus {
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(26, 111, 212, 0.12);
        }
        .field-input--password { padding-right: 3rem; }

        .field-error {
            display: block;
            font-size: 0.8rem;
            color: var(--red);
            margin-top: 0.35rem;
        }

        /* Submit button */
        .btn-submit {
            width: 100%;
            padding: 0.85rem;
            background: var(--blue);
            color: var(--white);
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.15s ease;
            font-family: inherit;
            margin-top: 0.5rem;
        }
        .btn-submit:hover { background: var(--blue-dark); }

        
        .validation-summary {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            margin-bottom: 1rem;
        }
        .validation-summary ul { list-style: none; padding: 0; margin: 0; }
        .validation-summary li { color: var(--red); font-size: 0.875rem; }

        .form-meta {
            display: flex;
            justify-content: flex-end;
            margin-top: 0.75rem;
        }
        .form-link {
            color: var(--blue);
            font-size: 0.875rem;
            font-weight: 600;
            text-decoration: none;
        }
        .form-link:hover { text-decoration: underline; }

        .form-footer {
            text-align: center;
            margin-top: 2rem;
            font-size: 0.9rem;
            color: var(--text-muted);
        }
        .form-footer a {
            color: var(--blue);
            font-weight: 600;
            text-decoration: none;
        }
        .form-footer a:hover { text-decoration: underline; }

      .error-page-btn {
          width:60%;
    display: inline-flex relative;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 2rem;
    background: #1e6fe0;
    margin-bottom:auto;
    color: #ffffff;
    border-radius: 4px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s ease;
}

    </style>
</head>
<body>
    <div class="split">
        <div class="panel-blue">
            <a asp-controller="Home" asp-action="Index" class="panel-link" aria-label="Popravka.ba početna">
                <img src="~/images/logo512.png" alt="Popravka.ba" class="panel-logo" />
                <span class="panel-logo-text">Popravka.ba</span>
            </a>
        </div>

        <div class="panel-form">
            <a asp-controller="Home" asp-action="Index" class="error-page-btn">
            Nazad na početnu
        </a>
            <div class="form-container">
                <h1 class="form-title">Dobrodošli nazad</h1>
                <p class="form-subtitle">Unesite vaše podatke za pristup nalogu.</p>

                <form asp-controller="Account" asp-action="Login" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                    <div class="field">
                        <label asp-for="Login.EmailUsername" class="field-label">E-mail adresa ili korisničko ime</label>
                        <div class="input-wrap">
                            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                                <polyline points="22,6 12,13 2,6"></polyline>
                            </svg>
                            <input asp-for="Login.EmailUsername" class="field-input" placeholder="vas@email.com" autocomplete="username" />
                        </div>
                        <span asp-validation-for="Login.EmailUsername" class="field-error"></span>
                    </div>

                    <div class="field">
                        <label asp-for="Login.Lozinka" class="field-label">Lozinka</label>
                        <div class="input-wrap">
                            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                            </svg>
                            <input asp-for="Login.Lozinka" id="lozinkaInput" type="password" class="field-input field-input--password" placeholder="••••••••" autocomplete="current-password" />
                            <button type="button" class="input-toggle" onclick="togglePassword()" aria-label="Prikaži lozinku">
                                <svg id="eyeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                    <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="Login.Lozinka" class="field-error"></span>
                        <div class="form-meta">
                            <a asp-controller="Account" asp-action="ZaboravljenaLozinka" class="form-link">Zaboravili ste lozinku?</a>
                        </div>
                    </div>

                    <button type="submit" class="btn-submit">Prijavi se</button>
                </form>

                <p class="form-footer">
                    Nemate račun?
                    <a asp-controller="Account" asp-action="Registracija">Registrujte se</a>
                </p>
            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            const input = document.getElementById('lozinkaInput');
            const icon = document.getElementById('eyeIcon');
            const isHidden = input.type === 'password';

            input.type = isHidden ? 'text' : 'password';

            // swap icon between "eye" and "eye-off"
            if (isHidden) {
                icon.innerHTML = `
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
                    <line x1="1" y1="1" x2="23" y2="23"></line>
                `;
            } else {
                icon.innerHTML = `
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                `;
            }
        }
    </script>
</body>
</html>