@{
    ViewData["Title"] = "Popravka.ba - Lozinka promijenjena";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body p-4 text-center">
                <div class="mb-3">
                    <i class="bi bi-check-circle" style="font-size: 2.5rem; color: var(--bs-success);"></i>
                </div>

                <h4 class="card-title mb-2">Lozinka je promijenjena</h4>
                <p class="text-muted mb-4">
                    Vaša lozinka je uspješno postavljena. 
                </p>

                <div class="d-grid">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                        Nazad na početnu
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>