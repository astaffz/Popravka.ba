@using PopravkaBa.Application.DTOs
@using PopravkaBa.Domain.Enums
@using PopravkaBa.Domain.Models
@using PopravkaBa.Web.Models.ViewModels
@{
    ViewData["Title"] = "Objavi oglas – Popravka.ba";

    var kategorije = (ViewBag.Kategorije as IEnumerable<Kategorija>) ?? Enumerable.Empty<Kategorija>();
    var mjesta = (ViewBag.Mjesta as IEnumerable<Mjesto>) ?? Enumerable.Empty<Mjesto>();
    string aktivniTab = ViewBag.AktivniTab ?? "usluge";

    var uslugeModel      = Model as ObjaviOglasUslugeDto;
    var majstoraModel    = Model as ObjaviOglasMajstoraDto;
    var radnoMjestoModel = Model as ObjaviOglasRadnoMjestoDto;

    bool mozeUsluge      = User.IsInRole("Klijent") || User.IsInRole("Administrator");
    bool mozeMajstora    = User.IsInRole("Majstor") || User.IsInRole("Firma") || User.IsInRole("Administrator");
    bool mozeRadnoMjesto = User.IsInRole("Firma") || User.IsInRole("Administrator");

    var msUsluge      = new KategorijeMultiSelectModel { Kategorije = kategorije, InputName = "KategorijeID", Selektovano = uslugeModel?.KategorijeID ?? new() };
    var msMajstora    = new KategorijeMultiSelectModel { Kategorije = kategorije, InputName = "KategorijeID", Selektovano = majstoraModel?.KategorijeID ?? new() };
    var msRadnoMjesto = new KategorijeMultiSelectModel { Kategorije = kategorije, InputName = "KategorijeID", Selektovano = radnoMjestoModel?.KategorijeID ?? new() };
}

<div class="container mt-4 mb-5" style="max-width:800px;">

    <a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none small d-block mb-3">
        <i class="fa-solid fa-arrow-left me-1"></i>Povratak
    </a>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <i class="fa-solid fa-circle-exclamation me-2"></i>Molimo ispravite greške u formi i pokušajte ponovo.
            @Html.ValidationSummary(false, "", new { @class = "mb-0 mt-2 small" })
        </div>
    }

    <h2 class="fw-bold mb-1">Objavi oglas</h2>
    <p class="text-muted mb-4">Odaberite vrstu oglasa koji želite objaviti.</p>

    <!-- Tabovi (server-side, bez JS) -->
    <ul class="nav nav-pills mb-4 gap-2">
        @if (mozeUsluge)
        {
            <li class="nav-item">
                <a class="nav-link @(aktivniTab == "usluge" ? "active" : "")"
                   asp-action="Index" asp-route-tab="usluge">Oglas usluge</a>
            </li>
        }
        @if (mozeMajstora)
        {
            <li class="nav-item">
                <a class="nav-link @(aktivniTab == "majstora" ? "active" : "")"
                   asp-action="Index" asp-route-tab="majstora">Oglas majstora</a>
            </li>
        }
        @if (mozeRadnoMjesto)
        {
            <li class="nav-item">
                <a class="nav-link @(aktivniTab == "radnomjesto" ? "active" : "")"
                   asp-action="Index" asp-route-tab="radnomjesto">Oglas za posao</a>
            </li>
        }
    </ul>

    <!-- ===== OGLAS USLUGE ===== -->
    @if (mozeUsluge && aktivniTab == "usluge")
    {
        <form asp-controller="ObjaviOglas" asp-action="ObjaviOglasUsluge" method="post" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3 d-flex align-items-center gap-2">
                        <span class="badge bg-primary rounded-circle" style="width:28px;height:28px;line-height:28px;font-size:.85rem;">1</span>
                        Osnovne informacije
                    </h5>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Naziv posla</label>
                        <input type="text" name="Naslov" class="form-control" value="@uslugeModel?.Naslov" placeholder="npr. Popravka vodovodnih cijevi" required />
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Kategorija</label>
                            <partial name="_KategorijeMultiSelect" model="msUsluge" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Lokacija</label>
                            <select name="MjestoID" class="form-select" required>
                                <option value="">Odaberite grad...</option>
                                @foreach (var m in mjesta)
                                {
                                    <option value="@m.MjestoID" selected="@(uslugeModel?.MjestoID == m.MjestoID)">@m.Naziv</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3 d-flex align-items-center gap-2">
                        <span class="badge bg-primary rounded-circle" style="width:28px;height:28px;line-height:28px;font-size:.85rem;">2</span>
                        Opis
                    </h5>
                    <label class="form-label fw-medium">Opis posla</label>
                    <textarea name="Opis" class="form-control" rows="5" required
                              placeholder="Opišite šta je potrebno uraditi, stanje, pristup i sve što smatrate važnim za izvršioca...">@uslugeModel?.Opis</textarea>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3 d-flex align-items-center gap-2">
                        <span class="badge bg-primary rounded-circle" style="width:28px;height:28px;line-height:28px;font-size:.85rem;">3</span>
                        Budžet
                    </h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Minimalni budžet (KM)</label>
                            <div class="input-group">
                                <input type="number" name="MinBudzet" class="form-control" min="0" value="@(uslugeModel?.MinBudzet)" placeholder="npr. 100" />
                                <span class="input-group-text">KM</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Maksimalni budžet (KM)</label>
                            <div class="input-group">
                                <input type="number" name="MaxBudzet" class="form-control" min="0" value="@(uslugeModel?.MaxBudzet)" placeholder="npr. 500" />
                                <span class="input-group-text">KM</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3">Slika oglasa <span class="text-muted fw-normal small">(opcionalno)</span></h5>
                    <input type="file" name="slika" class="form-control" accept="image/png,image/jpeg,image/webp" />
                    <div class="form-text">JPG, PNG ili WEBP – maksimalno 5MB.</div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Odustani</a>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fa-solid fa-paper-plane me-2"></i>Objavi oglas
                </button>
            </div>
        </form>
    }

    <!-- ===== OGLAS MAJSTORA ===== -->
    @if (mozeMajstora && aktivniTab == "majstora")
    {
        <form asp-controller="ObjaviOglas" asp-action="ObjaviOglasMajstora" method="post" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3 d-flex align-items-center gap-2">
                        <span class="badge bg-primary rounded-circle" style="width:28px;height:28px;line-height:28px;font-size:.85rem;">1</span>
                        Osnovne informacije
                    </h5>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Naziv usluge</label>
                        <input type="text" name="Naslov" class="form-control" value="@majstoraModel?.Naslov" placeholder="npr. Vodoinstalaterske usluge" required />
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Kategorija</label>
                            <partial name="_KategorijeMultiSelect" model="msMajstora" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Lokacija</label>
                            <select name="MjestoID" class="form-select" required>
                                <option value="">Odaberite grad...</option>
                                @foreach (var m in mjesta)
                                {
                                    <option value="@m.MjestoID" selected="@(majstoraModel?.MjestoID == m.MjestoID)">@m.Naziv</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3 d-flex align-items-center gap-2">
                        <span class="badge bg-primary rounded-circle" style="width:28px;height:28px;line-height:28px;font-size:.85rem;">2</span>
                        Opis usluge
                    </h5>
                    <textarea name="Opis" class="form-control" rows="5" required
                              placeholder="Opišite usluge koje nudite, iskustvo, opremu i certifikate...">@majstoraModel?.Opis</textarea>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3 d-flex align-items-center gap-2">
                        <span class="badge bg-primary rounded-circle" style="width:28px;height:28px;line-height:28px;font-size:.85rem;">3</span>
                        Cijena
                    </h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Cijena od (KM)</label>
                            <div class="input-group">
                                <input type="number" name="MinCijena" class="form-control" min="0" step="0.5" value="@(majstoraModel?.MinCijena)" placeholder="npr. 25" />
                                <span class="input-group-text">KM</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Tip isplate</label>
                            <select name="TipIsplate" class="form-select" required>
                                <option value="1" selected="@((int?)majstoraModel?.TipIsplate == 1)">Po satu</option>
                                <option value="0" selected="@((int?)majstoraModel?.TipIsplate == 0)">Jednokratno (fiksno)</option>
                                <option value="2" selected="@((int?)majstoraModel?.TipIsplate == 2)">Sedmično</option>
                                <option value="3" selected="@((int?)majstoraModel?.TipIsplate == 3)">Mjesečno</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3">Slika oglasa <span class="text-muted fw-normal small">(opcionalno)</span></h5>
                    <input type="file" name="slika" class="form-control" accept="image/png,image/jpeg,image/webp" />
                    <div class="form-text">JPG, PNG ili WEBP – maksimalno 5MB.</div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Odustani</a>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fa-solid fa-paper-plane me-2"></i>Objavi oglas
                </button>
            </div>
        </form>
    }

    <!-- ===== OGLAS ZA POSAO (RADNO MJESTO) ===== -->
    @if (mozeRadnoMjesto && aktivniTab == "radnomjesto")
    {
        <form asp-controller="ObjaviOglas" asp-action="ObjaviOglasRadnoMjesto" method="post" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()
            @{
                var uvjeti = radnoMjestoModel?.Uvjeti ?? new List<string>();
                var tipRm = (int?)radnoMjestoModel?.TipIsplate ?? 3;
            }

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3 d-flex align-items-center gap-2">
                        <span class="badge bg-primary rounded-circle" style="width:28px;height:28px;line-height:28px;font-size:.85rem;">1</span>
                        Osnovne informacije
                    </h5>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Naziv radnog mjesta</label>
                        <input type="text" name="Naslov" class="form-control" value="@radnoMjestoModel?.Naslov" placeholder="npr. Komercijalni prevoznik/ica" required />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Kategorija</label>
                            <partial name="_KategorijeMultiSelect" model="msRadnoMjesto" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Lokacija</label>
                            <select name="MjestoID" class="form-select" required>
                                <option value="">Odaberite grad...</option>
                                @foreach (var m in mjesta)
                                {
                                    <option value="@m.MjestoID" selected="@(radnoMjestoModel?.MjestoID == m.MjestoID)">@m.Naziv</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-medium">Tip zaposlenja</label>
                            <div class="d-flex flex-wrap gap-2 mt-1">
                                @foreach (var vz in Enum.GetValues<VrstaZaposlenja>())
                                {
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="VrstaZaposlenja"
                                               id="vz_@vz" value="@((int)vz)" required
                                               @(vz == (radnoMjestoModel?.VrstaZaposlenja ?? VrstaZaposlenja.PunoRadnoVrijeme) ? "checked" : "") />
                                        <label class="form-check-label" for="vz_@vz">
                                            @(vz switch {
                                                VrstaZaposlenja.PunoRadnoVrijeme  => "Stalni radni odnos",
                                                VrstaZaposlenja.PolaRadnogVrijema => "Pola radnog vremena",
                                                VrstaZaposlenja.UgovorDjelo       => "Ugovor o djelu",
                                                VrstaZaposlenja.Praksa            => "Praksa",
                                                VrstaZaposlenja.Sezonski          => "Sezonski",
                                                _ => vz.ToString()
                                            })
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Broj izvršilaca</label>
                            <input type="number" name="BrojIzvrsilaca" class="form-control" min="1" value="@(radnoMjestoModel?.BrojIzvrsilaca ?? 1)" required />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3 d-flex align-items-center gap-2">
                        <span class="badge bg-primary rounded-circle" style="width:28px;height:28px;line-height:28px;font-size:.85rem;">2</span>
                        Opis posla i uvjeti
                    </h5>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Opis radnog mjesta</label>
                        <textarea name="Opis" class="form-control" rows="5" required maxlength="800"
                                  placeholder="Opišite radno mjesto, odgovornosti, radno okruženje i sve što smatrate važnim za kandidata...">@radnoMjestoModel?.Opis</textarea>
                    </div>
                    <label class="form-label fw-medium">Uvjeti <span class="text-muted fw-normal">(opcionalno, max 3)</span></label>
                    <input type="text" name="Uvjeti" class="form-control mb-2" value="@(uvjeti.Count > 0 ? uvjeti[0] : null)" placeholder="npr. Vozačka dozvola kategorije C/CE" />
                    <input type="text" name="Uvjeti" class="form-control mb-2" value="@(uvjeti.Count > 1 ? uvjeti[1] : null)" placeholder="npr. CMR dokumentacija prednost" />
                    <input type="text" name="Uvjeti" class="form-control" value="@(uvjeti.Count > 2 ? uvjeti[2] : null)" placeholder="Dodatni uvjet" />

                    <label class="form-label fw-medium mt-3">Tražene vozačke dozvole <span class="text-muted fw-normal">(opcionalno)</span></label>
                    <div class="d-flex flex-wrap gap-2 mt-1">
                        @foreach (var vd in Enum.GetValues<VozackaDozvola>())
                        {
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="checkbox" name="VozackeDozvole"
                                       id="vd_@vd" value="@vd" @(radnoMjestoModel?.VozackeDozvole?.Contains(vd) == true ? "checked" : "") />
                                <label class="form-check-label" for="vd_@vd">@(vd == VozackaDozvola.Sve ? "Sve kategorije" : vd.ToString())</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3 d-flex align-items-center gap-2">
                        <span class="badge bg-primary rounded-circle" style="width:28px;height:28px;line-height:28px;font-size:.85rem;">3</span>
                        Prihod
                    </h5>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Minimalni prihod (KM)</label>
                            <input type="number" name="MinPrihod" class="form-control" min="0" value="@(radnoMjestoModel?.MinPrihod)" placeholder="1500" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Maksimalni prihod (KM)</label>
                            <input type="number" name="MaxPrihod" class="form-control" min="0" value="@(radnoMjestoModel?.MaxPrihod)" placeholder="2200" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Period isplate</label>
                            <select name="TipIsplate" class="form-select" required>
                                <option value="3" selected="@(tipRm == 3)">Mjesečno</option>
                                <option value="2" selected="@(tipRm == 2)">Sedmično</option>
                                <option value="1" selected="@(tipRm == 1)">Po satu</option>
                                <option value="0" selected="@(tipRm == 0)">Jednokratno</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3 d-flex align-items-center gap-2">
                        <span class="badge bg-primary rounded-circle" style="width:28px;height:28px;line-height:28px;font-size:.85rem;">4</span>
                        Slika oglasa <span class="text-muted fw-normal small">(opcionalno)</span>
                    </h5>
                    <input type="file" name="slika" class="form-control" accept="image/png,image/jpeg,image/webp" />
                    <div class="form-text">JPG, PNG ili WEBP – maksimalno 5MB.</div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Odustani</a>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fa-solid fa-paper-plane me-2"></i>Objavi oglas
                </button>
            </div>
        </form>
    }

</div>
