@section Scripts {
    <script>
        document.querySelectorAll('.profil-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.profil-tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                document.getElementById('panel-aktivni').style.display = tab.dataset.tab === 'aktivni' ? '' : 'none';
                document.getElementById('panel-zatvoreni').style.display = tab.dataset.tab === 'zatvoreni' ? '' : 'none';
            });
        });
    </script>
}
