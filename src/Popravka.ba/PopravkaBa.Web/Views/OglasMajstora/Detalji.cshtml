@model PopravkaBa.Web.Models.ViewModels.OglasMajstoraDetaljiViewModel
@using PopravkaBa.Domain.Enums
@{
    ViewData["Title"] = Model.Naslov + " – Popravka.ba";
    bool jeAktivan = Model.StatusOglasa == Status.Aktivan;

    Func<DateTime, string> relativnoVrijeme = (DateTime d) =>
    {
        var diff = DateTime.UtcNow - d.ToUniversalTime();
        if (diff.TotalMinutes < 60) return $"Prije {(int)diff.TotalMinutes} min.";
        if (diff.TotalHours < 24) return $"Prije {(int)diff.TotalHours}h.";
        return $"Prije {(int)diff.TotalDays} dana";
    };

    string tipIsplateLabel(TipIsplate t) => t switch
    {
        TipIsplate.PoSatu      => "po satu",
        TipIsplate.Jednokratno => "fiksno",
        TipIsplate.Sedmicno    => "sedmično",
        TipIsplate.Mjesecno    => "mjesečno",
        _ => t.ToString()
    };
}

<div class="container mt-4 mb-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!jeAktivan)
    {
        <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span><strong>Oglas je neaktivan.</strong> Ovaj oglas usluge trenutno nije aktivan.</span>
        </div>
    }

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Početna</a></li>
            <li class="breadcrumb-item"><a asp-controller="Pretraga" asp-action="Index">Pretraga</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Naslov</li>
        </ol>
    </nav>

    <div class="row g-4">

        <!-- Lijeva kolona: info o oglasu -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h1 class="h3 fw-bold mb-0">@Model.Naslov</h1>
                        <span class="badge @(jeAktivan ? "bg-success" : "bg-secondary") ms-3 flex-shrink-0">
                            @(jeAktivan ? "Aktivan" : "Neaktivan")
                        </span>
                    </div>

                    <div class="d-flex flex-wrap gap-3 text-muted small mb-3">
                        <span><i class="fa-solid fa-location-dot me-1"></i>@(Model.Lokacija ?? "—")</span>
                        <span><i class="fa-regular fa-clock me-1"></i>@relativnoVrijeme(Model.DatumObjave)</span>
                        <span>
                            <i class="fa-solid fa-circle-user me-1"></i>
                            <a href="/Profil/@Model.VlasnikId" class="text-decoration-none">@Model.VlasnikDisplayName</a>
                        </span>
                    </div>

                    @if (Model.Kategorije.Any())
                    {
                        <div class="mb-3">
                            @foreach (var kat in Model.Kategorije)
                            {
                                <span class="badge bg-primary-subtle text-primary me-1">@kat</span>
                            }
                        </div>
                    }

                    <div class="alert alert-info py-2 mb-3">
                        <i class="fa-solid fa-coins me-2"></i>
                        <strong>Cijena od:</strong> @Model.MinCijena.ToString("F0") KM
                        <span class="text-muted ms-1">(@tipIsplateLabel(Model.TipIsplate))</span>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Opis))
                    {
                        <hr />
                        <h5 class="fw-semibold">Opis usluge</h5>
                        <p class="mb-0" style="white-space: pre-line;">@Model.Opis</p>
                    }
                </div>
            </div>
        </div>

        <!-- Desna kolona -->
        <div class="col-lg-4">

            <!-- Izvršilac -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-3">
                    <h6 class="fw-semibold text-muted mb-3 text-uppercase" style="font-size:0.75rem;letter-spacing:.05em;">Izvršilac usluge</h6>
                    <a href="/Profil/@Model.VlasnikId" class="d-flex align-items-center gap-3 text-decoration-none text-body">
                        @if (!string.IsNullOrEmpty(Model.VlasnikSlika))
                        {
                            <img src="@Model.VlasnikSlika" alt="@Model.VlasnikDisplayName"
                                 class="rounded-circle" style="width:48px;height:48px;object-fit:cover;" />
                        }
                        else
                        {
                            <span class="rounded-circle bg-secondary-subtle d-flex align-items-center justify-content-center flex-shrink-0"
                                  style="width:48px;height:48px;font-size:1.5rem;color:#6c757d;">
                                <i class="fa-solid fa-circle-user"></i>
                            </span>
                        }
                        <div>
                            <span class="fw-semibold d-block">@Model.VlasnikDisplayName</span>
                            <span class="small text-muted">Pogledaj profil →</span>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Informacije -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-3">
                    <h6 class="fw-semibold text-muted mb-3 text-uppercase" style="font-size:0.75rem;letter-spacing:.05em;">Informacije o oglasu</h6>
                    <table class="table table-sm table-borderless mb-0">
                        <tbody>
                            <tr>
                                <td class="text-muted small">Lokacija</td>
                                <td class="fw-medium small text-end">@(Model.Lokacija ?? "—")</td>
                            </tr>
                            <tr>
                                <td class="text-muted small">Cijena</td>
                                <td class="fw-medium small text-end">od @Model.MinCijena.ToString("F0") KM</td>
                            </tr>
                            <tr>
                                <td class="text-muted small">Tip isplate</td>
                                <td class="fw-medium small text-end">@tipIsplateLabel(Model.TipIsplate)</td>
                            </tr>
                            <tr>
                                <td class="text-muted small">Status</td>
                                <td class="text-end">
                                    <span class="badge @(jeAktivan ? "bg-success" : "bg-secondary")">
                                        @(jeAktivan ? "Aktivan" : "Neaktivan")
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            @if (jeAktivan)
            {
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-3 text-center">
                        <p class="text-muted small mb-2">Zainteresirani ste za uslugu?</p>
                        <a href="/Profil/@Model.VlasnikId" class="btn btn-primary w-100">
                            <i class="fa-solid fa-envelope me-2"></i>Kontaktiraj izvršioca
                        </a>
                    </div>
                </div>
            }

            <!-- Vlasnik/Admin: uredi/obriši -->
            @if (Model.JeVlasnik)
            {
                <div class="card shadow-sm border-0">
                    <div class="card-body p-3 d-flex flex-column gap-2">
                        <a asp-controller="OglasMajstora" asp-action="UrediOglas" asp-route-id="@Model.OglasId"
                           class="btn btn-outline-primary btn-sm">
                            <i class="fa-solid fa-pen-to-square me-1"></i>Uredi oglas
                        </a>
                        <a asp-controller="OglasMajstora" asp-action="ObrisiOglas" asp-route-id="@Model.OglasId"
                           class="btn btn-outline-danger btn-sm">
                            <i class="fa-solid fa-trash me-1"></i>Obriši oglas
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
